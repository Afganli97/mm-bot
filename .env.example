# Telegram
TELEGRAM_BOT_TOKEN=123:abc

# Твой Telegram user_id.
# Узнать можно через @userinfobot
ALLOWED_USER_IDS=123456789

# DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO


# -------------------------
# API ключи
# -------------------------

# Etherscan V2 API. Нужен для Ethereum history.
ETHERSCAN_API_KEYS=key1,key2

# BscScan V2 API. Желательно для BSC history.
BSCSCAN_API_KEYS=your_bscscan_api_key

# Alchemy. RPC + alchemy_getTokenBalances для Ethereum.
ALCHEMY_API_KEY=your_alchemy_key

# Infura. Резервный RPC.
INFURA_API_KEY=your_infura_key

# Ankr Advanced API. Мультичейн EVM balances.
ANKR_API_KEY=your_ankr_key

# Moralis. Более полный список ERC20-балансов на Ethereum.
MORALIS_API_KEY=your_moralis_key

# Helius. Solana balances + Solana history.
HELIUS_API_KEY=your_helius_key

# Birdeye. Solana security/имена токенов.
BIRDEYE_API_KEY=your_birdeye_key

# Solscan. Пока не используется напрямую.
SOLSCAN_API_KEY=your_solscan_key


# -------------------------
# Анти-спам / качество токенов
# -------------------------
# Важно:
# - названия токенов НЕ используются для бана;
# - DexScreener НЕ используется как обязательный фильтр;
# - EVM security проверяется через GoPlus;
# - Solana security проверяется через Birdeye, если включено;
# - если сервис завис/ошибся, токен не блокируется автоматически;
# - fallback: баланс ровно 1 токен считается подозрительным.

ENABLE_GOPLUS_SECURITY=1
ENABLE_BIRDEYE_SECURITY=1

ENABLE_EXACT_ONE_SPAM_FILTER=1
EXACT_ONE_SPAM_FILTER_FOR_BALANCE=1
EXACT_ONE_SPAM_FILTER_FOR_HISTORY=0

MAX_HISTORY_BUY_TAX_PERCENT=30
MAX_HISTORY_SELL_TAX_PERCENT=30
MIN_HISTORY_HOLDER_COUNT=0

# Для Solana security по умолчанию лучше 0, чтобы не тормозить.
SOLANA_BALANCE_SECURITY_CHECK=0
SOLANA_HISTORY_SECURITY_CHECK=0

# Лимиты спам-проверок
MAX_BALANCE_SPAM_CHECKS=20
MAX_HISTORY_SPAM_CHECKS=100

# Timeout на один токен при спам-проверке
SPAM_CHECK_TIMEOUT_SECONDS=5

# Общий timeout на спам-отчёт
BALANCE_SPAM_TOTAL_TIMEOUT_SECONDS=60
HISTORY_SPAM_TOTAL_TIMEOUT_SECONDS=180


# -------------------------
# Solana balance/history stability
# -------------------------
SOLANA_BALANCE_TIMEOUT_SECONDS=45
SOLANA_PRICE_LOOKUP_TIMEOUT_SECONDS=5

# 0 = не делать price lookup для Solana balance, чтобы бот не зависал.
MAX_SOLANA_PRICE_LOOKUPS_PER_BALANCE=0

SOLANA_HISTORY_NAME_LOOKUP_TIMEOUT_SECONDS=30
MAX_SOLANA_HISTORY_NAME_LOOKUPS=20

DEFAULT_SOLANA_MAX_SIGNATURES_PER_ADDRESS=30
HARD_MAX_SOLANA_MAX_SIGNATURES_PER_ADDRESS=100

DEFAULT_SOLANA_HISTORY_TIMEOUT_SECONDS=600
HARD_MAX_SOLANA_HISTORY_TIMEOUT_SECONDS=900