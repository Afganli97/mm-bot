# Telegram
TELEGRAM_BOT_TOKEN=123:abc

# Твой Telegram user_id. Только этим пользователям бот будет отвечать.
# Узнать свой user_id можно через бота @userinfobot
ALLOWED_USER_IDS=123456789

# Логирование: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO


# -------------------------
# API ключи
# -------------------------

# Etherscan V2 API. Нужен для Ethereum history.
# Можно указать несколько ключей через запятую.
ETHERSCAN_API_KEYS=key1,key2

# BscScan V2 API. Желательно указать для полного BSC history,
# особенно чтобы учитывать native BNB transfers.
BSCSCAN_API_KEYS=your_bscscan_key

# Alchemy. Используется как RPC и для alchemy_getTokenBalances на Ethereum.
ALCHEMY_API_KEY=your_alchemy_key

# Infura. Резервный RPC-провайдер.
INFURA_API_KEY=your_infura_key

# Ankr Advanced API. Используется для мультичейн EVM балансов.
ANKR_API_KEY=your_ankr_key

# Moralis. Используется для более полного списка ERC20-балансов на Ethereum.
MORALIS_API_KEY=your_moralis_key

# Helius. Нужен для Solana балансов и Solana history.
HELIUS_API_KEY=your_helius_key

# Birdeye. Используется для имён/цен Solana-токенов.
BIRDEYE_API_KEY=your_birdeye_key

# Solscan. Пока не используется напрямую, оставлен для будущего расширения.
SOLSCAN_API_KEY=your_solscan_key
